---
import Layout from '../layouts/Layout.astro';


---
<Layout>
    <main>
        <section class="hero fade-in">
            <div class="container hero-container">
                <div class="hero-content">
                    <p class="hero-hook">Instálate en Europa sin sorpresas</p>
                    <h1 class="hero-headline">ASESORÍA MIGRATORIA CLARA Y CONFIABLE</h1>
                    <p class="hero-subheadline">Te acompañamos desde el minuto cero.</p>
                    <div class="hero-cta">
                        <button class="hero-btn" id="hero-calendly-button">
                            Agendar llamada gratuita
                        </button>
                        <div class="social-proof">
                            <div class="avatars">
                                <div class="avatar"></div>
                                <div class="avatar"></div>
                                <div class="avatar"></div>
                                <div class="avatar"></div>
                                <div class="avatar"></div>
                                <div class="more-count">+</div>
                            </div>
                            <p class="social-text">Más de <strong>150 personas</strong> ya se mudaron exitosamente</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="services" class="services section fade-in">
            <div class="container">
                <div class="services-grid">
                    <div class="service-card">
                        <div class="service-icon">📋</div>
                        <h3 class="service-title">Pareja de Hecho</h3>
                        <p class="service-description">Registro oficial de tu unión para obtener residencia</p>
                    </div>
                    <div class="service-card">
                        <div class="service-icon">🏛️</div>
                        <h3 class="service-title">NIE</h3>
                        <p class="service-description">Número de identificación de extranjero para trabajar</p>
                    </div>
                    <div class="service-card">
                        <div class="service-icon">🇪🇸</div>
                        <h3 class="service-title">Ciudadanía Española</h3>
                        <p class="service-description">Obtén la nacionalidad española por residencia</p>
                    </div>
                    <div class="service-card">
                        <div class="service-icon">📚</div>
                        <h3 class="service-title">Visa de Estudios</h3>
                        <p class="service-description">Estudia en España con todos los permisos necesarios</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="process" class="problem-solution section fade-in">
            <div class="container">
                <div class="solution-content">
                    <h2 class="solution-title">Tu proceso migratorio</h2>
                    <p class="solution-subtitle">Bajo control</p>
                    <p class="solution-text">Te damos un plan paso a paso para que entiendas cada requisito desde el inicio.</p>
                    <div class="solution-features">
                        <div class="feature-item">
                            <span class="feature-icon">✓</span>
                            <span>Avanza con un plan hecho a tu medida</span>
                        </div>
                        <div class="feature-item">
                            <span class="feature-icon">✓</span>
                            <span>Avanza con información siempre actualizada</span>
                        </div>
                        <div class="feature-item">
                            <span class="feature-icon">✓</span>
                            <span>No estás solo, te guiamos en cada etapa</span>
                        </div>
                    </div>
                    
                    <div class="cities-marquee">
                        <div class="marquee-container">
                            <div class="marquee-wrapper">
                                <div class="marquee-content">
                                    <span class="city">AMSTERDAM</span>
                                    <span class="separator">·</span>
                                    <span class="city">BARCELONA</span>
                                    <span class="separator">·</span>
                                    <span class="city">MADRID</span>
                                    <span class="separator">·</span>
                                    <span class="city">BRUSELAS</span>
                                    <span class="separator">·</span>
                                    <span class="city">AMSTERDAM</span>
                                    <span class="separator">·</span>
                                    <span class="city">BARCELONA</span>
                                    <span class="separator">·</span>
                                    <span class="city">MADRID</span>
                                    <span class="separator">·</span>
                                    <span class="city">BRUSELAS</span>
                                    <span class="separator">·</span>
                                    <span class="city">AMSTERDAM</span>
                                    <span class="separator">·</span>
                                    <span class="city">BARCELONA</span>
                                    <span class="separator">·</span>
                                    <span class="city">MADRID</span>
                                    <span class="separator">·</span>
                                    <span class="city">BRUSELAS</span>
                                    <span class="separator">·</span>
                                    <span class="city">AMSTERDAM</span>
                                    <span class="separator">·</span>
                                    <span class="city">BARCELONA</span>
                                    <span class="separator">·</span>
                                    <span class="city">MADRID</span>
                                    <span class="separator">·</span>
                                    <span class="city">BRUSELAS</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="cta-final section fade-in">
            <div class="container">
                <div class="cta-content">
                    <h2>¿Listo para empezar?</h2>
                    <p class="cta-text">Consulta gratuita de 30 minutos</p>
                    <div class="cta-cta">
                        <button class="cta-btn" id="hero-calendly-button">
                            Agendar consulta gratuita
                        </button>
                        <p class="cta-benefits">100% gratuito · Sin compromiso</p>
                    </div>
                </div>
            </div>
        </section>

        <footer id="contact" class="footer">
            <div class="container">
                <div class="footer-content">
                    <div class="footer-section">
                        <h3>Link & Live</h3>
                        <p>Asesoría migratoria especializada para tu nueva vida en Europa.</p>
                    </div>
                    <div class="footer-section">
                        <h4>Contacto</h4>
                        <a href="https://wa.me/+34692094141">WhatsApp</a>
                        <a href="https://instagram.com/link.andlive">Instagram</a>
                        <a href="mailto:linkandlive@gmail.com">Email</a>
                    </div>
                    <div class="footer-section">
                        <h4>Servicios</h4>
                        <a href="#services">Pareja de Hecho</a>
                        <a href="#services">NIE</a>
                        <a href="#services">Ciudadanía Española</a>
                        <a href="#services">Visa de Estudios</a>
                    </div>
                </div>
                <div class="footer-bottom">
                    <p>&copy; 2025 Link & Live. Todos los derechos reservados.</p>
                    <p class="credit">with love by Nicolas Jofre</p>
                </div>
            </div>
        </footer>

        <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
        <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript"></script>
        <script>
            function waitForCalendly() {
                if (typeof Calendly !== 'undefined') {
                    const calendlyButtons = document.querySelectorAll('#hero-calendly-button');
                    calendlyButtons.forEach(button => {
                        button.addEventListener('click', function() {
                            Calendly.initPopupWidget({url: 'https://calendly.com/linkandlive/consulta-gratuita'});
                        });
                    });
                } else {
                    setTimeout(waitForCalendly, 100);
                }
            }
            waitForCalendly();
        </script>
    </main>
</Layout>

<style>
    .hero {
        padding: 60px 0 40px 0;
        background-color: var(--color-bg);
        position: relative;
        min-height: auto !important;
        display: block !important;
        align-items: unset !important;
        width: 100%;
        overflow: visible;
    }



    .hero-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
        position: relative;
        z-index: 1;
    }

    .hero-content {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }

    .hero-hook {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-accent);
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.9;
        line-height: 1.3;
        position: relative;
        padding: 4px 0;
    }

    .hero-hook::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 40px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
        opacity: 0.6;
    }

    .hero-headline {
        font-size: 56px;
        font-weight: 800;
        line-height: 1.0;
        margin: 0;
        letter-spacing: -0.02em;
        color: var(--color-text);
        max-width: 700px;
        text-transform: uppercase;
    }

    .hero-subheadline {
        font-size: 22px;
        line-height: 1.4;
        margin: 0;
        color: #475569;
        max-width: 500px;
        font-weight: 400;
        letter-spacing: -0.01em;
    }

    .hero-cta {
        margin-top: 20px;
    }

    .hero-btn {
        background: linear-gradient(135deg, var(--color-accent), #d63b33);
        color: white;
        border: none;
        padding: 16px 32px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-block;
        font-family: var(--font-main);
        box-shadow: 0 8px 24px rgba(181, 52, 44, 0.25);
        text-transform: none;
        position: relative;
        overflow: hidden;
        letter-spacing: 0.02em;
        transform: translateY(0);
    }

    .hero-btn:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 60px rgba(181, 52, 44, 0.4);
        background: linear-gradient(135deg, #d63b33, var(--color-accent));
    }

    .hero-btn:active {
        transform: translateY(-2px);
        transition: transform 0.1s ease;
    }

    .hero-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }

    .hero-btn:hover::before {
        left: 100%;
    }

    .hero-btn .btn-arrow {
        transition: transform 0.3s ease;
    }

    .hero-btn:hover .btn-arrow {
        transform: translateX(4px);
    }

    .hero-note {
        font-size: 16px;
        opacity: 0.7;
        margin: 0;
        font-style: italic;
    }

    .social-proof {
        margin-top: 32px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }

    .avatars {
        display: flex;
        align-items: center;
        gap: -8px;
    }

    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f3f4f6, #d1d5db);
        border: 2px solid white;
        margin-left: -8px;
        position: relative;
    }

    .avatar:first-child {
        margin-left: 0;
    }

    .more-count {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: var(--color-accent);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 18px;
        margin-left: -8px;
        border: 2px solid white;
    }

    .social-text {
        font-size: 14px;
        color: #6b7280;
        margin: 0;
        text-align: center;
    }

    .social-text strong {
        color: var(--color-text);
    }

    .services {
        padding: 40px 0 60px 0;
    }

    .services-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
        max-width: 800px;
        margin: 0 auto;
    }

    .service-card {
        background-color: white;
        padding: 32px;
        border-radius: 16px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .service-card:hover {
